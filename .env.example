# Alcyone (Apache Atlas 2.5.0 Fork) Docker Configuration
# Copy to .env before use: cp .env.example .env

# * Build options
SKIPTESTS=true
PROFILE=dist,external-hbase-solr

# * Java version (valid: 8, 11)
# ^ Java 17은 JanusGraph 리플렉션 이슈로 빌드 시 11 권장
ATLAS_BASE_JAVA_VERSION=11
ATLAS_BUILD_JAVA_VERSION=11
ATLAS_SERVER_JAVA_VERSION=11

# * Component versions (2.5.0-rc0 defaults)
ATLAS_VERSION=2.5.0
UBUNTU_VERSION=20.04
KAFKA_VERSION=2.8.2

# * Kafka 모드 (기본: 내장)
# 외부 Kafka/ZK 컨테이너를 띄우려면 아래 주석 해제
# COMPOSE_PROFILES=kafka

# * Backend: PostgreSQL
ATLAS_BACKEND=postgres

# * PostgreSQL 설정
# 내장 컨테이너 사용 시 기본값 그대로 두면 됨
# 외부 PostgreSQL 사용 시 아래 값을 수정하고 docker-compose.yml에서 atlas-db 서비스 제거
ATLAS_DB_HOST=
ATLAS_DB_PORT=
ATLAS_DB_NAME=
ATLAS_DB_USER=
ATLAS_DB_PASSWORD=

# * Atlas Web UI
# URL: http://localhost:21000
ATLAS_ADMIN_USER=admin
ATLAS_ADMIN_PASSWORD=atlasR0cks!
